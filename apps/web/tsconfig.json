{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@workgate/shared": ["../../packages/shared/src/index.ts"],
      "@workgate/db": ["../../packages/db/src/index.ts"],
      "@workgate/github": ["../../packages/github/src/index.ts"],
      "@workgate/agents": ["../../packages/agents/src/index.ts"],
      "@workgate/runtime": ["../../packages/runtime/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
